# Python bytecode
__pycache__/
*.pyc

# ---------------------------------------------------------------
# Pipeline input data — client source files, never commit
# All files in these folders are either large raw xlsx exports
# (16–109 MB each) or copies of them. Use placeholder.txt to
# keep the folder structure tracked without the data.
# ---------------------------------------------------------------
01_fulfillment_merger/input/*
01_fulfillment_merger/output/*
02_data_processing/input/*
02_data_processing/output/*

# Keep placeholder files so the folders remain visible in the repo
!**/placeholder.txt

# Generated report files produced by generate.py
*-distress-analysis-*.html
*-distress-analysis-*.pdf

# Stray screenshots
Screenshot*.png
